{
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "name": "promptyard",
  "author": {
    "email": "willem.meints@pm.me",
    "name": "Willem Meints"
  },
  "contributors": [
    {
      "name": "Mika Krooswijk"
    }
  ],
  "entrypoint": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "bunx --bun @biomejs/biome lint",
    "lint:fix": "bunx --bun @biomejs/biome lint --write",
    "format": "bunx --bun @biomejs/biome format --write",
    "format:check": "bunx --bun @biomejs/biome format --check",
    "compile-windows-x64": "bun build --compile --target=bun-windows-x64 ./src/index.ts --outfile=dist/win-x64/promptyard.exe",
    "compile-windows-arm64": "bun build --compile --target=bun-windows-arm64 ./src/index.ts --outfile=dist/win-arm64/promptyard.exe",
    "compile-mac": "bun build --compile --target=bun-darwin-arm64 ./src/index.ts --outfile=dist/mac-arm64/promptyard",
    "compile-linux-x64": "bun build --compile --target=bun-linux-x64 ./src/index.ts --outfile=dist/linux-x64/promptyard",
    "compile-linux-arm64": "bun build --compile --target=bun-linux-arm64 ./src/index.ts --outfile=dist/linux-arm64/promptyard"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "frontmatter": "^0.0.3",
    "zod": "^4.3.6"
  }
}
